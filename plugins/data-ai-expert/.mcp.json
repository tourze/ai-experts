{
  "mcpServers": {
    "zai-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@z_ai/mcp-server"
      ],
      "env": {
        "Z_AI_API_KEY": "${Z_AI_API_KEY}",
        "Z_AI_MODE": "${Z_AI_MODE:-ZHIPU}"
      }
    },
    "web-search-prime": {
      "requiredEnv": [
        "Z_AI_API_KEY"
      ],
      "claude": {
        "type": "http",
        "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
        "headers": {
          "Authorization": "Bearer ${Z_AI_API_KEY}"
        }
      },
      "codex": {
        "command": "uvx",
        "args": [
          "mcp-proxy",
          "--transport",
          "streamablehttp",
          "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp"
        ],
        "env": {
          "API_ACCESS_TOKEN": "${Z_AI_API_KEY}"
        }
      }
    },
    "web-reader": {
      "requiredEnv": [
        "Z_AI_API_KEY"
      ],
      "claude": {
        "type": "http",
        "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp",
        "headers": {
          "Authorization": "Bearer ${Z_AI_API_KEY}"
        }
      },
      "codex": {
        "command": "uvx",
        "args": [
          "mcp-proxy",
          "--transport",
          "streamablehttp",
          "https://open.bigmodel.cn/api/mcp/web_reader/mcp"
        ],
        "env": {
          "API_ACCESS_TOKEN": "${Z_AI_API_KEY}"
        }
      }
    },
    "zread": {
      "requiredEnv": [
        "Z_AI_API_KEY"
      ],
      "claude": {
        "type": "http",
        "url": "https://open.bigmodel.cn/api/mcp/zread/mcp",
        "headers": {
          "Authorization": "Bearer ${Z_AI_API_KEY}"
        }
      },
      "codex": {
        "command": "uvx",
        "args": [
          "mcp-proxy",
          "--transport",
          "streamablehttp",
          "https://open.bigmodel.cn/api/mcp/zread/mcp"
        ],
        "env": {
          "API_ACCESS_TOKEN": "${Z_AI_API_KEY}"
        }
      }
    }
  }
}
