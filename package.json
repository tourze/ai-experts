{
  "name": "ai-experts",
  "private": true,
  "type": "module",
  "description": "Claude Code 与 Codex CLI 的本地 AI 能力组件库；src/components 编译到 dist/claude 与 dist/codex。",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:components": "vitest run tests/components",
    "typecheck:build": "tsc -p tsconfig.build.json",
    "typecheck:hooks": "tsc -p tsconfig.hooks.json",
    "build:components": "tsx src/build.ts",
    "check:components": "tsx src/build.ts --check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tourze/ai-experts.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
