{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/components/**/*.ts",
    "tests/types/**/*.ts"
  ],
  "exclude": [
    "src/components/procedures/sources/**/*.ts"
  ]
}
